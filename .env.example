# Copy to .env and adjust before: docker compose up -d --build
# cp .env.example .env
#
# Compose overrides REDIS_URL and DATABASE_URL to use service hostnames
# (redis / postgres). Values below are fine for local `go run` against
# published ports on localhost.

# --- Proxy ---
LISTEN_ADDR=:8080
# Legacy unprefixed paths (e.g. /v1/…) use UPSTREAM_*
UPSTREAM_URL=https://api.openai.com
UPSTREAM_HOST=api.openai.com
# Path-prefixed multi-provider routing (defaults enable /openai/* and /anthropic/*)
OPENAI_UPSTREAM_URL=https://api.openai.com
OPENAI_UPSTREAM_HOST=api.openai.com
ANTHROPIC_UPSTREAM_URL=https://api.anthropic.com
ANTHROPIC_UPSTREAM_HOST=api.anthropic.com

# Public URL customers open in the browser (signup/setup snippets + Stripe redirects)
PUBLIC_BASE_URL=http://localhost:8080

# Start in shadow for 24–48h; promote to enforce after validation
ENFORCEMENT_MODE=shadow

# --- Redis (required when ENFORCEMENT_MODE != off or ADMIN_API_KEY is set) ---
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=10
REDIS_COMMAND_TIMEOUT_MS=50
RESERVATION_TTL_SEC=300

# --- Budget estimation ---
DEFAULT_RESERVATION_ESTIMATE=4096
PROMPT_TOKEN_BUFFER=512
PRECHECK_TIMEOUT_MS=50
# Seeded on self-serve checkout.session.completed for budget:{org_id}:default
TRIAL_BUDGET_TOKENS=200000

# --- HTTP upstream pooling ---
HTTP_MAX_IDLE_CONNS=100
HTTP_MAX_IDLE_CONNS_PER_HOST=100
HTTP_IDLE_CONN_TIMEOUT_SEC=90

# --- Admin API + /ops Basic auth password (required; use a long random secret) ---
# /ops username is always "admin"; password = ADMIN_API_KEY
# Admin mint org/key is support fallback; customers use /signup
ADMIN_API_KEY=change-me-to-a-long-random-secret

# --- Postgres (hosted multi-tenant). When set: TokenGuard keys required on LLM path. ---
# Compose injects postgres hostname; for local go run use localhost:
DATABASE_URL=postgres://tokenguard:tokenguard@localhost:5432/tokenguard?sslmode=disable

# --- Stripe (required for self-serve /signup Checkout + webhook provisioning) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from `stripe listen` or Dashboard
# STRIPE_PRICE_INDIE=price_...      # also used for plan=trial Checkout
# STRIPE_PRICE_TEAM=price_...
# Must include {CHECKOUT_SESSION_ID} so /setup can reveal the one-time tg_ key:
# STRIPE_SUCCESS_URL=http://localhost:8080/setup?session_id={CHECKOUT_SESSION_ID}
# STRIPE_CANCEL_URL=http://localhost:8080/signup?canceled=1
# (If unset, defaults derive from PUBLIC_BASE_URL as above.)

# --- Slack (optional global fallback; prefer per-org webhook via /setup or admin PATCH) ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Single-provider legacy mode: set UPSTREAM_* only and call unprefixed /v1/…
# Multi-provider: use /openai/v1/… and /anthropic/v1/… on the same hostname (OPENAI_*/ANTHROPIC_* above).
